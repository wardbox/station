# Copy to .env (gitignored) and fill in, then source it before running tofu:
#   cp .env.example .env && $EDITOR .env && source .env

# Hetzner Cloud API token — project "station", Read & Write.
# The hcloud provider reads this automatically.
export HCLOUD_TOKEN=""

# Only needed once state moves to Hetzner Object Storage (see versions.tf).
# These are the S3 credentials from the Object Storage bucket, not the API token.
# export AWS_ACCESS_KEY_ID=""
# export AWS_SECRET_ACCESS_KEY=""
