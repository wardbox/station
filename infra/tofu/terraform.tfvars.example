# Copy to terraform.tfvars (gitignored) and adjust:
#   cp terraform.tfvars.example terraform.tfvars

# REQUIRED: your public IP, so only you can reach SSH (22) and the k3s API (6443).
# Find it:  curl -s ifconfig.me   then append /32
admin_cidrs = ["203.0.113.7/32"]

# Optional overrides — defaults are the "start small" opening position:
# name_prefix          = "station"
# datacenter           = "hil-dc1"      # Hillsboro, OR
# network_zone         = "us-west"
# image                = "ubuntu-24.04"
# k3s_version          = "v1.35.5+k3s1"
# control_plane_type   = "cax11"        # arm64, 2 vCPU / 4 GB
# agent_type           = "cax21"        # arm64, 4 vCPU / 8 GB
# agent_count          = 1
# network_cidr         = "10.0.0.0/16"
# subnet_cidr          = "10.0.1.0/24"
# ssh_public_key_path  = "~/.ssh/id_ed25519.pub"
# ssh_private_key_path = "~/.ssh/id_ed25519"
