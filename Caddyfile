# Featherweight static server for the baked-in blog. No TLS here — the cluster's
# ingress terminates HTTPS (build-spec: one front door). This just hands out the
# HTML that was built into /srv.
{
	admin off
	auto_https off
	persist_config off
}

:8080 {
	root * /srv
	encode gzip zstd

	# Liveness/readiness target for the pod.
	@health path /healthz
	respond @health "ok" 200

	# Katana's public page lives in the same static image, but presents as its own
	# place at katana.stationsystems.dev.
	@katana_root {
		host katana.stationsystems.dev
		path /
	}
	rewrite @katana_root /katana/index.html

	# Block known AI training/scraping bots. This is best-effort: honest bots are
	# stopped here; dishonest bots can lie about their user agent.
	@ai_bots header_regexp User-Agent "(?i)(GPTBot|ChatGPT-User|ClaudeBot|Claude-User|anthropic-ai|Google-Extended|PerplexityBot|CCBot|Bytespider|Amazonbot|Applebot-Extended|Meta-ExternalAgent|Meta-ExternalFetcher|FacebookBot|Diffbot|ImagesiftBot|Omgilibot|Omgili|YouBot|cohere-ai|AI2Bot|Kangaroo Bot|Scrapy|PetalBot)"
	respond @ai_bots "for humans only" 403

	file_server

	# Astro emits a real 404 page; serve it for missing paths.
	handle_errors {
		rewrite * /{err.status_code}.html
		file_server
	}

	# Minimal, honest hardening. Nothing security-theatre.
	header {
		-Server
		X-Content-Type-Options nosniff
		Referrer-Policy strict-origin-when-cross-origin
		X-Robots-Tag "noindex, nofollow, noarchive, nosnippet, noimageindex"
	}
}
