# Keep the build context small and the image clean. Source + content + lockfile
# go in; build output, deps, and tooling do not. Note: content posts live under
# src/content/**.md and are deliberately NOT ignored — posting is a git push
# (build-spec Principle 7).
node_modules
dist
.astro
.git
.github
.vscode
.idea
.dockerignore
Dockerfile
README.md
LICENSE
npm-debug.log*
pnpm-debug.log*
.DS_Store
.env
.env.*
*.tfstate
*.tfstate.*
**/*.tfstate
**/*.tfstate.*
*.tfvars
**/*.tfvars
!*.tfvars.example
!**/*.tfvars.example
.terraform
.terraform/**
**/.terraform
**/.terraform/**
kubeconfig
kubeconfig.yaml
**/kubeconfig
**/kubeconfig.yaml
**/.env
**/.env.*
!**/.env.example
