---
// A muted mono "now -" line (what you are actually working on) plus keyboard
// hints. Honest, low-key, human. The keys listed here are really wired.
import { site } from '../lib/site';
---

<div class="mt-6 flex items-center justify-between gap-3.5 border-t border-hairline pt-3.5 max-[560px]:flex-col max-[560px]:items-start max-[560px]:gap-3">
  <div class="font-mono text-[10px] tracking-[0.05em] text-faint">
    <span class="text-live" aria-hidden="true">&#9679;</span> now: {site.now}
  </div>
  <div class="flex items-center gap-3" aria-label="Keyboard hints">
    {
      site.keys.map((k) => (
        <span class="inline-flex items-center gap-1.5">
          <span class="kc">{k.kc}</span>
          <span class="label">{k.label}</span>
        </span>
      ))
    }
  </div>
</div>
