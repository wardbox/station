---
// The thin stat row beneath the prose: read time / stack / filed-under.
import { type Post } from '../lib/content';
import { postReadTime } from '../lib/readtime';

interface Props {
  post: Post;
}
const { post } = Astro.props;
const { data } = post.entry;
const readtime = postReadTime(post);
const [rtValue, rtUnit] = readtime.split(' ');
const hasAny = readtime || (data.stack?.length ?? 0) || (data.filed?.length ?? 0);
---

{
  hasAny && (
    <div class="mt-[26px] flex flex-wrap gap-8 border-t border-hairline pt-3.5">
      <div>
        <div class="label mb-1">Read</div>
        <div class="font-display text-lg font-medium text-text">
          {rtValue} <span class="text-[11px] uppercase tracking-[var(--track-label)] text-label">{rtUnit ?? 'min'}</span>
        </div>
      </div>
      {data.stack && data.stack.length > 0 && (
        <div>
          <div class="label mb-1">Stack</div>
          <div class="font-display text-lg font-medium text-text">{data.stack.join(' · ')}</div>
        </div>
      )}
      {data.filed && data.filed.length > 0 && (
        <div>
          <div class="label mb-1">Filed under</div>
          <div class="font-display text-lg font-medium text-text">{data.filed.join(' · ')}</div>
        </div>
      )}
    </div>
  )
}
