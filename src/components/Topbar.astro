---
// Edge chrome shared by post + section pages. The back link points to the
// natural parent; the wordmark always goes home.
import { site } from '../lib/site';

interface Props {
  backHref?: string;
  backLabel?: string;
}
const { backHref = '/', backLabel = 'index' } = Astro.props;
---

<div class="flex items-center justify-between border-b border-hairline px-[var(--pad-x)] py-4">
  <a class="back font-mono text-[11px] tracking-[0.05em] text-faint hover:text-text" href={backHref}
    ><span class="text-accent">&larr;</span> <span class="back-label">{backLabel}</span></a
  >
  <a class="font-display text-base font-medium tracking-[0.01em]" href="/">{site.name}</a>
</div>
