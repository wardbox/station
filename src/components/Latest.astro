---
// The single accent band = the latest post. The one place accent lives in this
// view - a functional spotlight, never decoration (Principle 2).
import { formatShort, postPath, type Post } from '../lib/content';

interface Props {
  post: Post;
}
const { post } = Astro.props;
const { data } = post.entry;
---

<a class="latest" href={postPath(post)}>
  <span class="latest-eyebrow">Latest</span>
  <span class="latest-title">{data.title}</span>
  <span class="latest-date">{formatShort(data.date)}</span>
</a>

<style>
  .latest {
    display: flex;
    align-items: baseline;
    gap: 12px;
    background: var(--accent);
    padding: 9px var(--pad-x);
  }
  .latest:hover .latest-title {
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .latest-eyebrow {
    font-size: 9.5px;
    letter-spacing: var(--track-label);
    text-transform: uppercase;
    color: var(--accent-tint);
    flex: 0 0 auto;
  }
  .latest-title {
    flex: 1 1 auto;
    font-family: var(--body);
    font-weight: var(--weight-medium);
    font-size: 14px;
    color: var(--on-accent);
  }
  .latest-date {
    font-family: var(--mono);
    font-size: 11px;
    color: var(--accent-tint);
    flex: 0 0 auto;
    white-space: nowrap;
  }
</style>
