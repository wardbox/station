---
// Columns by type. Each entry: title left, dotted leader, date or live status
// right. Accent stays reserved for active/featured states; cyan appears only
// for genuine live status.
import {
  formatShort,
  postPath,
  sectionPath,
  type Post,
  type PostType,
} from '../lib/content';

interface Props {
  sections: { type: PostType; label: string; posts: Post[] }[];
  // Hard cap per section on the index; omit to show everything (archive pages).
  limit?: number;
}
const { sections, limit } = Astro.props;
---

<div class="grid grid-cols-1 gap-8">
  {
    sections.map((section) => {
      const shown =
        limit != null ? section.posts.slice(0, limit) : section.posts;
      const hidden = section.posts.length - shown.length;
      return (
      <section class="col" data-section={section.type}>
        <div class="label mb-2 border-b border-hairline pb-2 text-label">{section.label}</div>
        {shown.map((post) => (
          <a class="group flex items-baseline py-1.5 text-sm" href={postPath(post)}>
            <span class="text-text transition-colors group-hover:text-text-bright group-focus-visible:text-text-bright">{post.entry.data.title}</span>
            <span class="mx-2 flex-1 -translate-y-1 border-b border-dotted border-lead-dot" aria-hidden="true" />
            {post.entry.data.live ? (
              <span class="font-mono text-xs tracking-wide text-live">LIVE</span>
            ) : (
              <time
                class="whitespace-nowrap font-mono text-xs text-faint"
                datetime={post.entry.data.date.toISOString()}
              >
                {formatShort(post.entry.data.date)}
              </time>
            )}
          </a>
        ))}
        {section.posts.length === 0 && (
          <div class="flex items-baseline py-1.5 font-mono text-xs text-label">nothing filed yet</div>
        )}
        {hidden > 0 && (
          <a class="mt-2 inline-block font-mono text-xs tracking-wide text-faint hover:text-text" href={sectionPath(section.type)}>
            +{hidden} more <span class="text-accent">&rarr;</span>
          </a>
        )}
      </section>
      );
    })
  }
</div>
