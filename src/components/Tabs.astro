---
// Section tabs with live counts. Active tab is the single accent-bearing mark
// here. Wired as real filters on the index (progressive enhancement).
import { type Post, type PostType } from '../lib/content';

interface Props {
  sections: { type: PostType; label: string; posts: Post[] }[];
}
const { sections } = Astro.props;
const total = sections.reduce((n, s) => n + s.posts.length, 0);
---

<nav class="tabs" aria-label="Sections" data-tabs>
  <button class="tab" type="button" data-filter="all" aria-current="true">
    All <span class="count">{total}</span>
  </button>
  {
    sections.map((s) => (
      <button class="tab" type="button" data-filter={s.type}>
        {s.label} <span class="count">{s.posts.length}</span>
      </button>
    ))
  }
</nav>

<style>
  .tabs {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
    margin-bottom: 22px;
  }
  .tab {
    font-family: var(--body);
    font-size: 11px;
    letter-spacing: 0.07em;
    padding: 5px 11px;
    color: var(--text-muted);
    background: transparent;
    border: 1px solid var(--hairline);
    cursor: pointer;
    transition: color 0.14s ease, border-color 0.14s ease;
  }
  .tab:hover {
    border-color: var(--dim);
  }
  .tab[aria-current='true'] {
    color: var(--text-bright);
    border-color: var(--dim);
  }
  .count {
    color: var(--faint);
  }
  .tab[aria-current='true'] .count {
    color: var(--count-active);
  }
</style>
