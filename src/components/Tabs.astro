---
// Section tabs with live counts. Active tab is the single accent-bearing mark
// here. Wired as real filters on the index (progressive enhancement).
import { type Post, type PostType } from '../lib/content';

interface Props {
  sections: { type: PostType; label: string; posts: Post[] }[];
}
const { sections } = Astro.props;
const total = sections.reduce((n, s) => n + s.posts.length, 0);
const tabClass = 'tab cursor-pointer border border-hairline bg-transparent px-3 py-1.5 font-body text-xs tracking-wide text-text-muted transition-colors hover:border-dim aria-[current=true]:border-dim aria-[current=true]:text-text-bright [&[aria-current=true]_span]:text-count-active';
---

<nav class="mb-6 flex flex-wrap gap-2" aria-label="Sections" data-tabs>
  <button class={tabClass} type="button" data-filter="all" aria-current="true">
    All <span class="text-faint">{total}</span>
  </button>
  {
    sections.map((s) => (
      <button class={tabClass} type="button" data-filter={s.type}>
        {s.label} <span class="text-faint">{s.posts.length}</span>
      </button>
    ))
  }
</nav>
