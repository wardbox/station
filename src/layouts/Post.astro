---
// The reading field. Text is the design - words in a good face on a calm
// field. Chrome lives at the edges (telemetry, topbar, stats), never in prose.
import Base from './Base.astro';
import Telemetry from '../components/Telemetry.astro';
import Topbar from '../components/Topbar.astro';
import PostHeader from '../components/PostHeader.astro';
import PostStats from '../components/PostStats.astro';
import { sectionPath, type Post } from '../lib/content';

interface Props {
  post: Post;
}
const { post } = Astro.props;
const { data } = post.entry;
---

<Base title={data.title} description={data.summary}>
  <main class="field">
    <Telemetry />
    <Topbar backHref={sectionPath(post.type)} backLabel={post.type} />

    <article class="article">
      <PostHeader post={post} />
      <div class="prose">
        <slot />
      </div>
      <PostStats post={post} />
    </article>
  </main>
</Base>

<script>
  // The back link defaults to this post's section (its parent). But if you
  // actually arrived from the index, send you back there instead. Honest:
  // it reflects where you came from, and degrades to the section without JS.
  const back = document.querySelector<HTMLAnchorElement>('.back');
  const label = back?.querySelector<HTMLElement>('.back-label');
  if (back && label && document.referrer) {
    try {
      const ref = new URL(document.referrer);
      if (ref.origin === location.origin && ref.pathname === '/') {
        back.setAttribute('href', '/');
        label.textContent = 'index';
      }
    } catch {}
  }
</script>

<style>
  .article {
    padding: 30px var(--pad-x) 36px;
  }
</style>

<style is:global>
  /* Restrained prose - a curated set of elements, no markdown soup. The reading
     column carries the writing and nothing competes with it (Principle 7). */
  .prose {
    max-width: 60ch;
    font-size: 16px;
    line-height: 1.72;
    color: var(--text);
  }
  .prose > * + * {
    margin-top: 1.1em;
  }
  .prose h2,
  .prose h3 {
    font-family: var(--display);
    font-weight: var(--weight-medium);
    color: var(--text);
    line-height: 1.15;
    margin-top: 1.6em;
  }
  .prose h2 {
    font-size: 24px;
  }
  .prose h3 {
    font-size: 19px;
  }
  .prose a {
    color: var(--text);
    text-decoration: underline;
    text-decoration-color: var(--accent);
    text-underline-offset: 3px;
  }
  .prose strong {
    font-weight: var(--weight-medium);
    color: var(--text);
  }
  .prose em {
    font-style: italic;
  }
  .prose blockquote {
    border-left: 2px solid var(--hairline);
    padding-left: 18px;
    color: var(--faint);
  }
  .prose ul,
  .prose ol {
    padding-left: 1.3em;
  }
  .prose ul {
    list-style: none;
  }
  .prose ul li {
    position: relative;
  }
  .prose ul li::before {
    content: '';
    position: absolute;
    left: -1.1em;
    top: 0.75em;
    width: 0.3em;
    height: 1px;
    background: var(--label);
  }
  .prose ol {
    list-style: decimal;
  }
  .prose li + li {
    margin-top: 0.4em;
  }
  .prose code {
    font-family: var(--mono);
    font-size: 0.85em;
    color: var(--text);
    background: var(--code-bg);
    border: 1px solid var(--hairline);
    border-radius: 3px;
    padding: 0.1em 0.35em;
  }
  .prose pre {
    font-size: 13px;
    line-height: 1.6;
    padding: 18px;
    border: 1px solid var(--hairline);
    border-radius: 4px;
    overflow-x: auto;
  }
  .prose pre code {
    background: none;
    border: 0;
    padding: 0;
  }
  .prose hr {
    border: 0;
    border-top: 1px solid var(--hairline);
    margin-block: 2em;
  }
</style>
