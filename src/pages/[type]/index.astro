---
// Per-section archive - the full list for one type. Where "+N more" lands.
import Base from '../../layouts/Base.astro';
import Telemetry from '../../components/Telemetry.astro';
import Topbar from '../../components/Topbar.astro';
import SectionIndex from '../../components/SectionIndex.astro';
import {
  POST_TYPES,
  TYPE_LABEL,
  getSections,
  type PostType,
} from '../../lib/content';

export async function getStaticPaths() {
  return POST_TYPES.map((type) => ({ params: { type } }));
}

const { type } = Astro.params as { type: PostType };
const sections = await getSections();
const section = sections.find((s) => s.type === type);
if (!section) throw new Error(`No section found for type "${type}"`);
---

<Base title={TYPE_LABEL[type]}>
  <main class="field">
    <Telemetry />
    <Topbar />
    <div class="body">
      <SectionIndex sections={[section]} />
    </div>
  </main>
</Base>

<style>
  .body {
    padding: 24px var(--pad-x);
  }
</style>
