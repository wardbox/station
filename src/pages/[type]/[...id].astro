---
// One route for every section. Maps /writing/…, /builds/…, /notes/… onto the
// matching collection. New section files need no new routing - drop and push.
import { render } from 'astro:content';
import { getAllPosts, type Post } from '../../lib/content';
import PostLayout from '../../layouts/Post.astro';

export async function getStaticPaths() {
  const posts = await getAllPosts();
  return posts.map((post) => ({
    params: { type: post.type, id: post.entry.id.replace(/\.md$/, '') },
    props: { post },
  }));
}

interface Props {
  post: Post;
}
const { post } = Astro.props as Props;
const { Content } = await render(post.entry);
---

<PostLayout post={post}>
  <Content />
</PostLayout>
